# Copy to .env and set your values. Never commit .env or real keys.
# OPENAI_API_KEY is required for the LangGraph contract analysis worker.
OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
MAX_PAGE_SIZE=20

# Overridden in Docker by docker-compose (use for local runs only)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/serenlex
REDIS_URL=redis://localhost:6379/0
REPORTS_DIR=reports
